# Copy to .env for local development
PORT=3001
HOST=0.0.0.0

# Frontend URL (must match where the React app is hosted)
CLIENT_URL=http://localhost:5173

# Optional: extra origins (comma-separated), e.g. preview deployments
# CLIENT_URLS=https://branch.scribblepro.pages.dev

MAX_ROOMS=500

# Set by hosting platforms in production (Render, Fly.io, etc.)
# NODE_ENV=production
