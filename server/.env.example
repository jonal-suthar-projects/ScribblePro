# Copy to .env for local development
PORT=3001
HOST=0.0.0.0

# Frontend URL (must match where the React app is hosted)
CLIENT_URL=http://localhost:5173

# Optional: extra origins (comma-separated), e.g. preview deployments
# CLIENT_URLS=https://branch.scribblepro.pages.dev

MAX_ROOMS=500

# Redis (Upstash: use the "Redis URL" with rediss:// — required for production on Render)
# REDIS_URL=rediss://default:password@host.upstash.io:6379

# Room/session TTL (seconds)
# ROOM_TTL_SECONDS=7200
# LOBBY_TTL_SECONDS=3600
# SESSION_TTL_SECONDS=86400
# RECONNECT_GRACE_MS=90000
# ROOM_EXPIRE_INTERVAL_MS=300000

# Set by hosting platforms in production (Render, Fly.io, etc.)
# NODE_ENV=production
